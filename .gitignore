# ═══════════════════════════════════════════════════════════════════
# MediSync FullStack - Root .gitignore
# ═══════════════════════════════════════════════════════════════════

# ─── Java / Spring Boot (medisync-api) ────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*

# Maven
.mvn/
mvnw
mvnw.cmd

# Gradle (in case of future migration)
.gradle/
build/

# Spring Boot
medisync-api/application-local.yml
medisync-api/application-prod.yml

# ─── Angular / Node (medisync-frontend) ──────────────────────────
node_modules/
dist/
tmp/
out-tsc/
bazel-out/
npm-debug.log
yarn-error.log
.angular/cache/
docs/

# ─── IDE / Editors ───────────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.project
.classpath
.settings/
.factorypath

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
nb-configuration.xml

# ─── OS Files ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── Environment / Secrets ───────────────────────────────────────
.env
.env.*
*.pem
*.key

# ─── Testing / Coverage ─────────────────────────────────────────
coverage/
*.lcov
testem.log
/libpeerconnection.log

# ─── Build Artifacts ─────────────────────────────────────────────
*.tgz
*.zip
*.tar.gz

# ─── Uploaded Files (served from filesystem) ─────────────────────
uploads/
